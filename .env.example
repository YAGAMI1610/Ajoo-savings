# ---- Frontend (Vite) ----
# Deployed CircleFactory address on Monad testnet. Leave as the zero address
# until you've run contracts/script/Deploy.s.sol — the app runs in a clearly
# labeled "contracts not deployed" state until this is set.
VITE_CIRCLE_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: override which USDC (or other stablecoin) ERC20 contract circles
# use. Defaults to Circle's official USDC on Monad Testnet
# (0x534b2f3A21130d7a60830c2Df862319e593943A3) if left unset.
VITE_USDC_TESTNET_ADDRESS=

# Optional: override the default public Monad testnet RPC with your own.
VITE_MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# ---- Contracts (Foundry) ----
# Wallet used to deploy CircleFactory. Never commit this.
DEPLOYER_PRIVATE_KEY=

MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_EXPLORER_API_KEY=
